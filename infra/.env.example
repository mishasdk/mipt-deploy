# PostgreSQL
MLFLOW_DB_NAME=mlflow
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=mlflow

# ML flow artifacts storage
MLFLOW_S3_ENDPOINT_URL=https://storage.yandexcloud.net
MLFLOW_S3_BUCKET_NAME=mishasdk-object-storage
MLFLOW_S3_DIR_NAME=mlflow-artifacts

# Yandex Cloud SA secrets
YC_ACCESS_KEY_ID=YC...
YC_SECRET_ACCESS_KEY=YC...

# Airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_FERNET_KEY=secret...
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Nginx gateway
PROXY_USER=admin
PROXY_PASSWORD=admin
